# ─── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Embeddings (optional — falls back to TF-IDF if not set) ─────────────────
VOYAGE_API_KEY=pa-...

# ─── News API (optional — falls back to RSS if not set) ──────────────────────
ALPACA_NEWS_API_KEY=
ALPACA_NEWS_SECRET=

# ─── Portfolio ─────────────────────────────────────────────────────────────────
STARTING_CAPITAL=100000

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
